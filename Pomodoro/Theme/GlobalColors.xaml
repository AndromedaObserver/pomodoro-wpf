<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Accent colors (mode indicator colors) -->
	<Color x:Key="main">#FFFFFF</Color>			<!-- Content bg → White -->
	<Color x:Key="secondary">#38858A</Color>		<!-- Short break accent -->
	<Color x:Key="third">#397097</Color>			<!-- Long break accent -->
	<Color x:Key="border">#333333</Color>			<!-- Primary text → Dark -->
	<Color x:Key="transparent">#33E3E3E3</Color>

	<Color x:Key="maindark">#FFF0F0</Color>			<!-- Focus mode active tab bg (light red) -->
	<Color x:Key="secondarydark">#E8F6F6</Color>	<!-- Short break active tab bg -->
	<Color x:Key="thirddark">#E8F0F6</Color>		<!-- Long break active tab bg -->
	<Color x:Key="borderdark">#666666</Color>		<!-- Secondary text -->
	<Color x:Key="transparentdark">#33A3A3A3</Color>

	<Color x:Key="maindarker">#BA4949</Color>		<!-- Title bar / Mode accent -->
	<Color x:Key="secondarydarker">#38858A</Color>	<!-- Short break title bar -->
	<Color x:Key="thirddarker">#397097</Color>		<!-- Long break title bar -->
	<Color x:Key="borderdarker">#222222</Color>		<!-- Emphasis text -->

	<SolidColorBrush x:Key="mainColor" Color="{StaticResource main}" />
	<SolidColorBrush x:Key="secondaryColor" Color="{StaticResource secondary}" />
	<SolidColorBrush x:Key="thirdColor" Color="{StaticResource third}" />
	<SolidColorBrush x:Key="borderColor" Color="{StaticResource border}" />
	<SolidColorBrush x:Key="transparentColor" Color="{StaticResource transparent}" />

	<SolidColorBrush x:Key="mainColorDark" Color="{StaticResource maindark}" />
	<SolidColorBrush x:Key="secondaryColorDark" Color="{StaticResource secondarydark}" />
	<SolidColorBrush x:Key="thirdColorDark" Color="{StaticResource thirddark}" />
	<SolidColorBrush x:Key="borderColorDark" Color="{StaticResource borderdark}" />
	<SolidColorBrush x:Key="transparentColorDark" Color="{StaticResource transparentdark}" />

	<SolidColorBrush x:Key="mainColorDarker" Color="{StaticResource maindarker}" />
	<SolidColorBrush x:Key="secondaryColorDarker" Color="{StaticResource secondarydarker}" />
	<SolidColorBrush x:Key="thirdColorDarker" Color="{StaticResource thirddarker}" />
	<SolidColorBrush x:Key="borderColorDarker" Color="{StaticResource borderdarker}" />

</ResourceDictionary>
