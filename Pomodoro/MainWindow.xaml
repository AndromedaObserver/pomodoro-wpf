<Window x:Class="Pomodoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:Pomodoro"
        Title="个人成长app"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        Icon="app.ico">
    <Window.Resources>
        <!-- ======================== DataTemplates ======================== -->
        <DataTemplate x:Key="TodoItemTemplate">
            <Border Margin="0,2" Padding="8,6" CornerRadius="6"
                    Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                              IsChecked="{Binding IsDone}"
                              Checked="TodoCheckChanged"
                              Unchecked="TodoCheckChanged">
                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                   TextWrapping="Wrap" MaxWidth="260"/>
                    </CheckBox>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="⏱" Width="28" Height="28"
                                FontSize="14" Margin="4,0,2,0"
                                Background="#E8F4FD" Foreground="#4A90D9"
                                BorderBrush="#B8D8F8" BorderThickness="1"
                                Cursor="Hand" ToolTip="分配到时间格子"
                                Click="AssignTodoToCells_Click"
                                Tag="{Binding Title}"/>
                        <Button Content="✕" Width="28" Height="28"
                                FontSize="12" Margin="2,0,0,0"
                                Background="#FDE8E8" Foreground="#D94A4A"
                                BorderBrush="#F8C8C8" BorderThickness="1"
                                Cursor="Hand" ToolTip="删除待办"
                                Click="DeleteTodo_Click"
                                Tag="{Binding Id}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="WeightHistoryItemTemplate">
            <Border Margin="0,2" Padding="8,6" CornerRadius="6"
                    Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat=yyyy/MM/dd}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="#555555" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding Weight, StringFormat=F1}"
                               FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="#1565C0"/>
                    <TextBlock Grid.Column="2" Text="kg" FontSize="12"
                               VerticalAlignment="Center" Foreground="#999999" Margin="4,0,10,0"/>
                    <Button Grid.Column="3" Content="删除" Width="48" Height="26"
                            FontSize="11" Background="#FDE8E8" Foreground="#D94A4A"
                            BorderBrush="#F8C8C8" BorderThickness="1"
                            Cursor="Hand"
                            Click="DeleteWeight_Click"
                            Tag="{Binding Date}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ======================== Title Bar ======================== -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource mainColorDarker}"
                CornerRadius="8 8 0 0"
                BorderThickness="1 1 1 0"
                BorderBrush="{StaticResource borderColorDarker}"
                MouseLeftButtonDown="MouseDragBar">
            <Border x:Name="Border1"
                    Height="36" VerticalAlignment="Top"
                    CornerRadius="0 8 0 0"
                    Background="{StaticResource mainColorDarker}">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="🍅" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="个人成长app" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                   Foreground="{StaticResource borderColor}"
                                   MouseLeftButtonDown="MouseDragBar"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button Content="—" Width="34" Height="28"
                                Background="Transparent" Foreground="{StaticResource borderColor}"
                                BorderThickness="0" FontSize="14" FontWeight="Bold"
                                Cursor="Hand"
                                Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton" Content="☐" Width="34" Height="28"
                                Background="Transparent" Foreground="{StaticResource borderColor}"
                                BorderThickness="0" FontSize="14"
                                Cursor="Hand"
                                Click="MaximizeButton_Click"/>
                        <Button Content="✕" Width="34" Height="28"
                                Background="Transparent" Foreground="{StaticResource borderColor}"
                                BorderThickness="0" FontSize="13" FontWeight="Bold"
                                Cursor="Hand"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- ======================== Sidebar ======================== -->
        <Border Grid.Row="1" Grid.Column="0"
                Width="180" Background="#F5F5F5"
                CornerRadius="0 0 0 8"
                BorderBrush="{StaticResource borderColorDarker}"
                BorderThickness="1 0 1 1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,16,0,0">
                    <!-- 待办 -->
                    <Border x:Name="SidebarTodoBorder"
                            Height="44" Margin="12,4" CornerRadius="8"
                            Background="{StaticResource mainColorDark}"
                            Cursor="Hand"
                            MouseLeftButtonDown="SidebarTodo_Click">
                        <TextBlock Text="📋 待办" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource borderColor}"/>
                    </Border>
                    <!-- 番茄钟 -->
                    <Border x:Name="SidebarPomodoroBorder"
                            Height="44" Margin="12,4" CornerRadius="8"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="SidebarPomodoro_Click">
                        <TextBlock Text="🍅 番茄钟" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource borderColor}"/>
                    </Border>
                    <!-- 健身 -->
                    <Border x:Name="SidebarWeightBorder"
                            Height="44" Margin="12,4" CornerRadius="8"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="SidebarWeight_Click">
                        <TextBlock Text="💪 健身" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource borderColor}"/>
                    </Border>
                    <!-- 日记 -->
                    <Border x:Name="SidebarDiaryBorder"
                            Height="44" Margin="12,4" CornerRadius="8"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="SidebarDiary_Click">
                        <TextBlock Text="📝 日记" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource borderColor}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="12,0,12,16">
                    <Border Height="36" CornerRadius="6" Background="#E8E8E8" Cursor="Hand"><Button Content="⚙ 设置" Background="Transparent" Foreground="{StaticResource borderColor}" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Click="SettingsBtn_Click"/></Border>
                    <TextBlock x:Name="VersionArea"
                               Text="1.0.0.0" FontSize="10" FontWeight="Light"
                               Foreground="#999999" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======================== Content Area ======================== -->
        <Border x:Name="Border2" Grid.Row="1" Grid.Column="1"
                Background="{StaticResource mainColor}"
                CornerRadius="0 0 8 8"
                BorderBrush="{StaticResource borderColorDarker}"
                BorderThickness="0 1 1 1">
            <Grid>
                <!-- ===== Mode Tab Bar ===== -->
                <Border x:Name="ModeTabBar"
                        Height="56" VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <Grid HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Border3" Grid.Column="0"
                                Width="110" Height="32" CornerRadius="6"
                                Background="{StaticResource mainColorDark}"
                                Margin="0,0,4,0">
                            <Button x:Name="PomodoroMode" Content="专注"
                                    Background="Transparent" Foreground="{StaticResource borderColor}"
                                    BorderThickness="0" FontSize="14" FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="PomodoroMode_Click"/>
                        </Border>
                        <Border x:Name="Border4" Grid.Column="1"
                                Width="110" Height="32" CornerRadius="6"
                                Background="Transparent"
                                Margin="0,0,4,0">
                            <Button x:Name="ShortBreakMode" Content="短休息"
                                    Background="Transparent" Foreground="{StaticResource borderColor}"
                                    BorderThickness="0" FontSize="14" FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="ShortBreakMode_Click"/>
                        </Border>
                        <Border x:Name="Border5" Grid.Column="2"
                                Width="110" Height="32" CornerRadius="6"
                                Background="Transparent">
                            <Button x:Name="LongBreakMode" Content="长休息"
                                    Background="Transparent" Foreground="{StaticResource borderColor}"
                                    BorderThickness="0" FontSize="14" FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="LongBreakMode_Click"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ===== Pomodoro View ===== -->
                <Grid x:Name="PomodoroView" Visibility="Collapsed" Margin="40,56,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Focus Timer -->
                    <Border x:Name="TimerPomodoro" Grid.Row="0"
                            Height="180" Margin="0,20,0,0"
                            Background="{StaticResource transparentColor}"
                            CornerRadius="16" BorderThickness="1"
                            BorderBrush="{StaticResource transparentColorDark}">
                        <TextBlock x:Name="TimerPomodoroText"
                                   Text="25:00"
                                   Foreground="{StaticResource borderColor}"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   FontSize="72" FontWeight="Bold"/>
                    </Border>
                    <TextBlock x:Name="ProgressLabel" Grid.Row="1"
                               Text="专注 1/4" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource borderColorDark}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="NextTimerPreview" Grid.Row="1"
                               Text="→ 短休息 5分钟" FontSize="12"
                               Foreground="{StaticResource borderColorDark}"
                               HorizontalAlignment="Center" Margin="0,28,0,0"/>

                    <!-- Short Break Timer -->
                    <Border x:Name="TimerShortBreak" Grid.Row="0"
                            Height="180" Margin="0,20,0,0"
                            Background="{StaticResource transparentColor}"
                            CornerRadius="16" BorderThickness="1"
                            BorderBrush="{StaticResource transparentColorDark}"
                            Visibility="Hidden">
                        <TextBlock x:Name="TimerShortBreakText"
                                   Text="05:00"
                                   Foreground="{StaticResource borderColor}"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   FontSize="72" FontWeight="Bold"/>
                    </Border>
                    <TextBlock x:Name="ProgressLabelShort" Grid.Row="1"
                               Text="短休息" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource borderColorDark}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="NextTimerPreviewShort" Grid.Row="1"
                               Text="→ 专注 25分钟" FontSize="12"
                               Foreground="{StaticResource borderColorDark}"
                               HorizontalAlignment="Center" Margin="0,28,0,0"/>

                    <!-- Long Break Timer -->
                    <Border x:Name="TimerLongBreak" Grid.Row="0"
                            Height="180" Margin="0,20,0,0"
                            Background="{StaticResource transparentColor}"
                            CornerRadius="16" BorderThickness="1"
                            BorderBrush="{StaticResource transparentColorDark}"
                            Visibility="Hidden">
                        <TextBlock x:Name="TimerLongBreakText"
                                   Text="15:00"
                                   Foreground="{StaticResource borderColor}"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   FontSize="72" FontWeight="Bold"/>
                    </Border>
                    <TextBlock x:Name="ProgressLabelLong" Grid.Row="1"
                               Text="长休息" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource borderColorDark}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="NextTimerPreviewLong" Grid.Row="1"
                               Text="→ 专注 25分钟" FontSize="12"
                               Foreground="{StaticResource borderColorDark}"
                               HorizontalAlignment="Center" Margin="0,28,0,0"/>

                    <!-- Controls -->
                    <Border x:Name="ControlsBorder" Grid.Row="2"
                            Background="{StaticResource transparentColor}"
                            CornerRadius="45" Height="64"
                            Padding="6" Margin="0,16,0,0"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Border Width="46" Height="46" CornerRadius="23" Background="#E8E8E8" Cursor="Hand"><Button Content="⏹" Background="Transparent" Foreground="{StaticResource borderColor}" BorderThickness="0" FontSize="20" Click="Stop_Click"/></Border>
                            <Border Width="46" Height="46" CornerRadius="23" Margin="8,0,0,0" Background="#BA4949" Cursor="Hand"><ToggleButton x:Name="playPausePlayerButton" Content="▶" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" IsChecked="False" Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked"/></Border>
                            <Border Width="46" Height="46" CornerRadius="23" Margin="8,0,0,0" Background="#E8E8E8" Cursor="Hand"><Button Content="⟳" Background="Transparent" Foreground="{StaticResource borderColor}" BorderThickness="0" FontSize="20" Click="Restart_Click"/></Border>
                            <Border Width="46" Height="46" CornerRadius="23" Margin="8,0,0,0" Background="#E8E8E8" Cursor="Hand"><Button x:Name="SkipButton" Content="⏭" Background="Transparent" Foreground="{StaticResource borderColor}" BorderThickness="0" FontSize="18" Click="SkipButton_Click"/></Border>
                        </StackPanel>
                    </Border>

                    <!-- Alarm Stop Row -->
                    <Border x:Name="AlarmStopRow" Grid.Row="3"
                            Visibility="Collapsed"
                            Margin="0,16,0,0" HorizontalAlignment="Center">
                        <Border Width="160" Height="44" CornerRadius="8" Background="#D94A4A" Cursor="Hand"><Button x:Name="StopAlarmButton" Content="🔔 停止铃声" Background="Transparent" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Click="StopAlarmButton_Click"/></Border>
                    </Border>
                </Grid>

                <!-- ===== Todo View ===== -->
                <!-- ===== Todo View ===== -->
                <Grid x:Name="TodoView" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Left Column: 24h Grid + Time Blocks -->
                    <ScrollViewer Grid.Row="0" Grid.RowSpan="5" Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="0,4,0,0">
                        <StackPanel>
                            <Grid x:Name="Hour24Grid" Margin="12,4,4,4"/>

                            <Border x:Name="TimeBlockActiveCard"
                                    Width="240" Margin="12,8,4,4" Padding="12,10"
                                    CornerRadius="8" Background="#FFFFFF"
                                    BorderBrush="#E0E0E0" BorderThickness="1"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock x:Name="ActiveBlockName" Text="💼 工作"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource borderColor}"/>
                                    <TextBlock x:Name="ActiveBlockTime" Text="已过 00:00"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="#BA4949" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:Name="TimeBlockList"
                                          Margin="12,4,4,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2" Padding="6,4" CornerRadius="4"
                                                Background="#F8F9FA">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="4" CornerRadius="2"
                                                        Margin="0,0,8,0"
                                                        Background="{Binding ColorHex}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}"
                                                           FontSize="11" Foreground="#888888"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TimeBlockEmpty"
                                       Text="暂无记录" FontSize="12"
                                       Foreground="#BBBBBB"
                                       HorizontalAlignment="Center"
                                       Margin="12,4,4,8"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right Column Row 0: Todo Input -->
                    <StackPanel Grid.Row="0" Grid.Column="1"
                                Orientation="Horizontal" Margin="4,8,12,0">
                        <TextBox x:Name="TodoInput" Width="280" Height="32"
                                 FontSize="13" VerticalContentAlignment="Center"
                                 Padding="8,2" BorderBrush="#D0D0D0"
                                 Background="White"
                                 KeyDown="TodoInput_KeyDown"/>
                        <Border Width="72" Height="32" CornerRadius="4" Background="#BA4949" Margin="8,0,0,0" Cursor="Hand">
                            <Button Content="➕ 添加" Background="Transparent" Foreground="White" FontSize="12" FontWeight="SemiBold" BorderThickness="0" Click="AddTodo_Click"/>
                        </Border>
                        <TextBlock x:Name="TodayTotalLabel" Text="今日无记录" FontSize="11"
                                   Foreground="{StaticResource borderColorDark}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Right Column Row 1: Preset Panel -->
                    <WrapPanel x:Name="TimeBlockPresetPanel" Grid.Row="1" Grid.Column="1"
                               Margin="4,6,12,4"/>

                    <!-- Right Column Row 2: Selection Bar -->
                    <Border x:Name="SelectionBar" Grid.Row="2" Grid.Column="1"
                            Height="44" Margin="4,4,12,4"
                            Background="#F0F8FF" CornerRadius="8"
                            BorderBrush="#B8D8F8" BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="12,0">
                            <Border Height="28" CornerRadius="4" Background="#E8F4FD" BorderBrush="#B8D8F8" BorderThickness="1" Cursor="Hand">
                                <Button x:Name="SelectFromNowBtn" Content="📌 从现在选中" Padding="8,0" Background="Transparent" Foreground="#4A90D9" FontSize="11" FontWeight="SemiBold" BorderThickness="0" Click="SelectFromNow_Click"/>
                            </Border>
                            <Border Height="28" CornerRadius="4" Margin="6,0,0,0" Background="#E8F4FD" BorderBrush="#B8D8F8" BorderThickness="1" Cursor="Hand">
                                <Button x:Name="SelectAllBtn" Content="全选" Padding="8,0" Background="Transparent" Foreground="#4A90D9" FontSize="11" FontWeight="SemiBold" BorderThickness="0" Click="SelectAll_Click"/>
                            </Border>
                            <TextBlock x:Name="SelectedCountLabel"
                                       Text="已选中 0 个时间段" FontSize="11"
                                       Foreground="#4A90D9"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <Border Height="28" CornerRadius="4" Margin="6,0,0,0" Background="#FDE8E8" BorderBrush="#F8C8C8" BorderThickness="1" Cursor="Hand">
                                <Button x:Name="ClearSelectedBtn" Content="清除" Padding="8,0" Background="Transparent" Foreground="#D94A4A" FontSize="11" FontWeight="SemiBold" BorderThickness="0" IsEnabled="False" Click="ClearSelected_Click"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Right Column Row 3: Todo List -->
                    <ListBox x:Name="TodoListBox" Grid.Row="3" Grid.Column="1"
                             Margin="4,6,12,4"
                             ItemTemplate="{StaticResource TodoItemTemplate}"
                             Background="Transparent"
                             BorderThickness="0"/>

                    <!-- Right Column Row 4: Time Stats Chart (centered below todo list) -->
                    <Border Grid.Row="4" Grid.Column="1"
                            Margin="4,0,12,12" Padding="16,12"
                            CornerRadius="8" Background="#FAFAFA"
                            BorderBrush="#E8E8E8" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <Canvas x:Name="TimeStatsCanvas"
                                    Width="200" Height="200"
                                    HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TimeStatsSummary"
                                       Text="今日暂无记录" FontSize="12"
                                       Foreground="#888888"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,8"/>
                            <WrapPanel x:Name="TimeStatsLegend"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <!-- ===== Diary View ===== -->
                <local:DiaryView x:Name="DiaryView" Visibility="Collapsed"/>

                <!-- ===== Weight View ===== -->
                <Grid x:Name="WeightView" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Chart -->
                    <Border x:Name="WeightChartHost" Grid.Row="0" Grid.Column="0"
                            Height="280" Margin="12,12,8,0"
                            Background="White" CornerRadius="8"
                            BorderBrush="#E0E0E0" BorderThickness="1"/>

                    <!-- Stats Panel -->
                    <Border Grid.Row="0" Grid.Column="1"
                            Width="220" Margin="0,12,12,0" Padding="16"
                            Background="White" CornerRadius="8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📊 统计" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource borderColor}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="当前体重" FontSize="11" Foreground="#888888"/>
                            <TextBlock x:Name="CurrentWeightLabel" Text="-- kg"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0,2,0,8"/>
                            <TextBlock Text="BMI" FontSize="11" Foreground="#888888"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock x:Name="BmiLabel" Text="--"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource borderColor}"/>
                                <TextBlock x:Name="BmiCategoryLabel" Text=""
                                           FontSize="12" VerticalAlignment="Bottom"
                                           Foreground="#888888" Margin="6,0,0,2"/>
                            </StackPanel>
                            <TextBlock Text="变化" FontSize="11" Foreground="#888888"
                                       Margin="0,12,0,0"/>
                            <TextBlock x:Name="WeightChangeLabel" Text="--"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#2E7D32" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Input Section -->
                    <Border Grid.Row="1" Grid.Column="0"
                            Margin="12,8,12,8" Padding="16"
                            Background="White" CornerRadius="8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📝 记录体重" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource borderColor}"
                                       Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <DatePicker x:Name="WeightDatePicker" Width="140"
                                            FontSize="12" Margin="0,0,12,0"/>
                                <TextBox x:Name="WeightInput" Width="100"
                                         FontSize="18" FontWeight="Bold"
                                         VerticalContentAlignment="Center"
                                         PreviewTextInput="WeightInput_PreviewTextInput"/>
                                <TextBlock Text="kg" FontSize="14" VerticalAlignment="Center"
                                           Foreground="#888888" Margin="6,0,0,0"/>
                                <Border Width="60" Height="30" CornerRadius="4" Background="#1565C0" Margin="12,0,0,0" Cursor="Hand"><Button Content="保存" Background="Transparent" Foreground="White" FontSize="12" FontWeight="SemiBold" BorderThickness="0" Click="SaveWeight_Click"/></Border>
                            </StackPanel>
                            <TextBlock Text="⚙ 设置" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#888888" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <TextBlock Text="身高" FontSize="12" VerticalAlignment="Center"
                                           Foreground="#666666" Width="40"/>
                                <TextBox x:Name="HeightInput" Width="80"
                                         FontSize="13" VerticalContentAlignment="Center"
                                         PreviewTextInput="WeightInput_PreviewTextInput"
                                         TextChanged="HeightInput_TextChanged"/>
                                <TextBlock Text="cm" FontSize="12" VerticalAlignment="Center"
                                           Foreground="#888888" Margin="6,0,20,0"/>
                                <TextBlock Text="目标体重" FontSize="12" VerticalAlignment="Center"
                                           Foreground="#666666" Width="60"/>
                                <TextBox x:Name="GoalWeightInput" Width="80"
                                         FontSize="13" VerticalContentAlignment="Center"
                                         PreviewTextInput="WeightInput_PreviewTextInput"
                                         TextChanged="GoalWeightInput_TextChanged"/>
                                <TextBlock Text="kg" FontSize="12" VerticalAlignment="Center"
                                           Foreground="#888888" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- History List -->
                    <ListBox x:Name="WeightHistoryList" Grid.Row="1" Grid.Column="1"
                             Width="220" Margin="0,8,12,8"
                             ItemTemplate="{StaticResource WeightHistoryItemTemplate}"
                             Background="Transparent"
                             BorderThickness="0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ======================== Resize Grip ======================== -->
        <Rectangle Grid.Row="1" Grid.Column="1"
                   Width="16" Height="16"
                   Fill="Transparent"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Cursor="SizeNWSE"
                   MouseLeftButtonDown="ResizeGrip_MouseDown"/>
    </Grid>
</Window>
