<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置" Height="480" Width="400"
        FontFamily="Calibri" FontWeight="Bold"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource mainColor}"
        x:Class="Pomodoro.SettingsWindow">
    <Border CornerRadius="5" BorderThickness="1" BorderBrush="{StaticResource borderColorDarker}">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⚙ 设置" FontSize="18" Foreground="{StaticResource borderColor}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="&#x2715;"
                        Click="CloseBtn_Click"
                        Background="Transparent" Foreground="{StaticResource borderColor}"
                        FontSize="16" BorderThickness="0"
                        Width="30" Height="30"
                        Cursor="Hand"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Margin="0,5,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 声音设置 -->
                <TextBlock Text="■ 声音" Foreground="{StaticResource borderColor}" FontSize="14" Margin="0,5,0,5"/>
                <Grid Margin="10,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="音量" Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" FontSize="13"/>
                    <Slider Grid.Column="1" x:Name="VolumeSlider" Minimum="0" Maximum="100"
                            Value="100" TickFrequency="10" IsSnapToTickEnabled="True"
                            Foreground="{StaticResource borderColor}" Margin="5,0"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="VolumeLabel" Text="100%"
                               Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="13"/>
                </Grid>
                <CheckBox x:Name="MuteCheckBox" Content="静音"
                          Foreground="{StaticResource borderColor}"
                          FontSize="13" Margin="10,0,0,5"
                          Checked="MuteCheckBox_Changed" Unchecked="MuteCheckBox_Changed"/>

                <!-- 环境音（专注时播放） -->
                <Grid Margin="10,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="环境音" Foreground="{StaticResource borderColor}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <ComboBox Grid.Column="1" x:Name="AmbientSoundCombo"
                              FontSize="13" Height="26"/>
                    <Button Grid.Column="2" Content="试听"
                            Click="PreviewAmbientBtn_Click"
                            Background="{StaticResource mainColorDarker}"
                            Foreground="{StaticResource borderColor}"
                            BorderThickness="0" FontSize="12" Height="24" Width="50"
                            Cursor="Hand" Margin="5,0,0,0"/>
                </Grid>

                <!-- 闹钟音 -->
                <Grid Margin="10,5,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="闹钟音" Foreground="{StaticResource borderColor}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <ComboBox Grid.Column="1" x:Name="AlarmSoundCombo"
                              FontSize="13" Height="26"/>
                    <Button Grid.Column="2" Content="试听"
                            Click="PreviewAlarmBtn_Click"
                            Background="{StaticResource mainColorDarker}"
                            Foreground="{StaticResource borderColor}"
                            BorderThickness="0" FontSize="12" Height="24" Width="50"
                            Cursor="Hand" Margin="5,0,0,0"/>
                </Grid>

                <!-- 计时设置 -->
                <TextBlock Text="■ 计时" Foreground="{StaticResource borderColor}" FontSize="14" Margin="0,5,0,5"/>
                <Grid Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="专注时长" Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Grid.Column="1" x:Name="pomodoroInput" 
                             TextAlignment="Center" FontSize="13" Height="24"/>

                    <TextBlock Grid.Row="1" Text="短休息" Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="shortBreakInput" 
                             TextAlignment="Center" FontSize="13" Height="24"/>

                    <TextBlock Grid.Row="2" Text="长休息" Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="longBreakInput" 
                             TextAlignment="Center" FontSize="13" Height="24"/>

                    <TextBlock Grid.Row="3" Text="循环次数" Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="cycleInput" 
                             TextAlignment="Center" FontSize="13" Height="24"/>
                </Grid>

                <!-- 高级设置 -->
                <TextBlock Text="■ 高级" Foreground="{StaticResource borderColor}" FontSize="14" Margin="0,10,0,5"/>
                <CheckBox x:Name="InfiniteFocusCheckBox" Content="无限专注（专注结束后跳过休息）"
                          Foreground="{StaticResource borderColor}"
                          FontSize="13" Margin="10,0,0,5"/>
                <CheckBox x:Name="AutoStartCheckBox" Content="倒计时结束后自动开始下一轮"
                          Foreground="{StaticResource borderColor}"
                          FontSize="13" Margin="10,0,0,10"/>

                <!-- 窗口尺寸 -->
                <TextBlock Text="■ 窗口" Foreground="{StaticResource borderColor}" FontSize="14" Margin="0,10,0,5"/>
                <Grid Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>  
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="宽度" Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Grid.Column="1" x:Name="widthInput"
                             TextAlignment="Center" FontSize="13" Height="24"/>
                    <TextBlock Grid.Row="1" Text="高度" Foreground="{StaticResource borderColor}" 
                               VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="heightInput"
                             TextAlignment="Center" FontSize="13" Height="24"/>
                </Grid>
            </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Grid Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="取消" 
                        Click="CancelBtn_Click"
                        Background="{StaticResource mainColorDark}"
                        Foreground="{StaticResource borderColor}"
                        BorderThickness="0" FontSize="14" Height="32"
                        Cursor="Hand" Margin="0,0,5,0"/>
                <Button Grid.Column="1" Content="保存"
                        Click="SaveBtn_Click"
                        Background="{StaticResource mainColorDarker}"
                        Foreground="{StaticResource borderColor}"
                        BorderThickness="0" FontSize="14" Height="32"
                        Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>